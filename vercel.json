{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "api": {
      "root": "server/",
      "entrypoint": "cmd/api/main.go"
    },
    "web": {
      "root": ".",
      "framework": "vite",
      "outputDirectory": "dist"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": { "service": "api" }
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
