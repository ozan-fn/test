generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Report {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  battery_percent Int
  battery_voltage Float
  signal          Int
  provider        String
  timestamp       DateTime @default(now())

  @@map("reports")
}